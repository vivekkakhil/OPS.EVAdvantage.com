                <asp:LinkButton ID="lnkLogout" runat="server" Text="Log Out"  CausesValidation="false" 
                        style="font-size: small; color: #FFFFFF; font-weight: 700" 
                        onclick="lnkLogout_Click"></asp:LinkButton>
                </td>
            </tr>
                </table>
        </div>
