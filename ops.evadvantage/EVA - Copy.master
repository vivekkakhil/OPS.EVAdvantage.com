        <td align="left">
        <asp:Label ID="lblWelcome" runat="server" Text="Welcome" 
                style="font-size: small; color: #FFFFFF; font-weight: 700"></asp:Label>
                  <asp:Label ID="lblUser" runat="server"
                style="font-size: small; color: #FFFFFF; "></asp:Label></td>
