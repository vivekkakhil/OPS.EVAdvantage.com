                    &nbsp;&nbsp;&nbsp; 
                   
                        <asp:ImageButton ID="imgbtnContact" runat="server" CausesValidation="false"
                ImageUrl="images/contact_btn.jpg" onclick="imgbtnContact_Click" />
                        &nbsp;&nbsp;&nbsp;
            
                <asp:ImageButton ID="imgbtnFaq" runat="server" CausesValidation="false"
                ImageUrl="images/faq_btn.jpg" onclick="imgbtnFaq_Click" />
        </div>
        <div id="div_top" runat="server" class="top">
        <br />
